    {"点": 2, "論理": "AND"},
    {"点": 3, "判定": "条件満たせば発火"},
    {"点": 4, "割り込み": "通常"}
  ],
  "BACK": [
    {"点": 0, "記憶への影響": "緑色で記録"},
    {"点": 1, "次回の影響": "バランス維持"},
    {"点": 2, "学習内容": "安定状態として記憶"},
    {"点": 3, "持続時間": "長期"},
    {"点": 4, "解消条件": "なし（自然減衰）"}
  ]
}


# ================================================================================
# 全感情Cross構造の統合
# ================================================================================

生成する 感情DNA_Cross構造 = {
  "Layer_0_ホメオスタシス": {
    "体温": 体温Cross,
    "エネルギー": エネルギーCross,
    "痛み": 痛みCross,
    "酸素": 酸素Cross,
    "総点数": 20  # 各5点 x 4種類
  },

  "Layer_1_神経伝達物質": {
    "ドーパミン": ドーパミンCross,
    "ノルアドレナリン": ノルアドレナリンCross,
    "セロトニン": セロトニンCross,
    "総点数": 45  # 各15点 x 3種類
  },

  "Layer_2_感情割り込み": {
    "恐怖": 恐怖Cross,
    "怒り": 怒りCross,
    "好奇心": 好奇心Cross,
    "悲しみ": 悲しみCross,
    "喜び": 喜びCross,
    "安心": 安心Cross,
    "総点数": 180  # 各30点 x 6感情
  },

  "メタデータ": {
    "総層数": 3,
    "総点数": 245,  # 20 + 45 + 180
    "構造": "3層感情DNA",
    "説明": "ホメオスタシス閾値 → 神経伝達物質の極性 → 感情割り込みルール"
  }
}


# ================================================================================
# Cross構造による感情判定
# ================================================================================

定義する Cross感情を判定 受け取る [生理状態Cross, 認知状態Cross] = {
  # Layer 0: ホメオスタシス偏差を計算
  体温偏差 = 計算する_偏差(生理状態Cross.体温, 体温Cross)
  エネルギー偏差 = 計算する_偏差(生理状態Cross.エネルギー, エネルギーCross)
  痛み偏差 = 計算する_偏差(生理状態Cross.痛み, 痛みCross)
  酸素偏差 = 計算する_偏差(生理状態Cross.酸素, 酸素Cross)

  # Layer 1: 神経伝達物質を計算
  ドーパミン量 = 計算する_神経伝達物質(認知状態Cross, ドーパミンCross)
  ノルアドレナリン量 = 計算する_神経伝達物質(認知状態Cross, ノルアドレナリンCross)
  セロトニン量 = 計算する_神経伝達物質(認知状態Cross, セロトニンCross)

  # Layer 2: 各感情の発火条件をCross構造で判定
  候補感情Cross = []

  # 恐怖判定
  もし 判定する_発火条件(恐怖Cross, 生理状態Cross, 認知状態Cross):
    候補感情Cross += [恐怖Cross]

  # 怒り判定
  もし 判定する_発火条件(怒りCross, 生理状態Cross, 認知状態Cross):
    候補感情Cross += [怒りCross]

  # 好奇心判定
  もし 判定する_発火条件(好奇心Cross, 生理状態Cross, 認知状態Cross):
    候補感情Cross += [好奇心Cross]

  # 悲しみ判定
  もし 判定する_発火条件(悲しみCross, 生理状態Cross, 認知状態Cross):
    候補感情Cross += [悲しみCross]

  # 喜び判定
  もし 判定する_発火条件(喜びCross, 生理状態Cross, 認知状態Cross):
    候補感情Cross += [喜びCross]

  # 安心判定
  もし 判定する_発火条件(安心Cross, 生理状態Cross, 認知状態Cross):
    候補感情Cross += [安心Cross]

  # 優先度が最も高い感情を選択
  もし 長さ(候補感情Cross) == 0:
    返す なし

  最高優先度 = 0
  支配感情Cross = なし

  繰り返す 感情 in 候補感情Cross:
    もし 感情.UP[0].優先度 > 最高優先度:
      最高優先度 = 感情.UP[0].優先度
      支配感情Cross = 感情

  # 感情Crossを適用（全ノードのリソース配分を変更）
  適用する_感情Cross(支配感情Cross)

  返す 支配感情Cross
}


# ================================================================================
# Cross構造による記憶への色付け
# ================================================================================

定義する Cross記憶に色を付ける 受け取る [経験Cross, 感情Cross] = {
  # 感情の色を経験Crossに追加
  経験Cross.色 = 感情Cross.UP[4].色
  経験Cross.感情名 = 感情Cross の名前
  経験Cross.感情強度 = 感情Cross.UP[3].強度
  経験Cross.同調モード = 感情Cross.LEFT[0].同調モード

  # リソース配分をCross構造として記録
  経験Cross.リソース配分Cross = 感情Cross.RIGHT

  # 神経伝達物質の状態もCross構造として記録
  経験Cross.神経伝達物質Cross = {
    "ドーパミン": ドーパミン量,
    "ノルアドレナリン": ノルアドレナリン量,
    "セロトニン": セロトニン量
  }

  返す 経験Cross
}


# ================================================================================
# 説明
# ================================================================================

"""
この実装の重要なポイント:

1. **全てがCross構造**
   - ホメオスタシス閾値もCross
   - 神経伝達物質の放出条件もCross
   - 感情の発火条件もCross

2. **3層の階層構造**
   - Layer 0 (20点): ホメオスタシス閾値
   - Layer 1 (45点): 神経伝達物質の極性
   - Layer 2 (180点): 感情割り込みルール
   - 総計: 245点のCross構造

3. **6軸の完全活用**
   - UP/DOWN: 値の範囲、偏差
   - RIGHT/LEFT: 条件、減衰
   - FRONT/BACK: 発火条件、記憶への影響

4. **DNAとしての記述**
   - これらのCross構造は遺伝的に決定
   - 学習では変化しない
   - すべての個体が同じ感情DNA Cross構造を持つ

5. **実行時の動作**
   - 生理状態Cross + 認知状態Cross → 神経伝達物質Cross → 感情Cross → リソース配分Cross
   - 全てがCross構造として処理される
"""
