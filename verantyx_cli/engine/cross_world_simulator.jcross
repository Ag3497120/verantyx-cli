# ═══════════════════════════════════════════════════════════
# 4. シミュレーション処理
# ═══════════════════════════════════════════════════════════

# 物体の状態更新（1フレーム）
生成する 状態更新Cross = {
  "FRONT": [
    {"点": 0, "処理": "物理法則を適用"},
    {"点": 1, "ステップ": [
      "重力を適用",
      "速度を更新",
      "位置を更新",
      "衝突判定",
      "アフォーダンス更新"
    ]}
  ]
}

# 操作コマンド: 物体を移動
# （jcross_operation_commands.pyと統合）
ラベル 物体を移動

  # パラメータ取得
  取り出す z     # z座標
  取り出す y     # y座標
  取り出す x     # x座標
  取り出す 物体ID

  # 物体表現Crossを取得
  物体ID
  実行する world.get_object

  # 新しい位置を設定
  入れる 物体表現
  取り出す 物体表現

  # RIGHT軸に位置を格納
  0
  入れる 点インデックス
  x
  実行する cross.set_axis_value "RIGHT" 点インデックス "位置" x

  1
  入れる 点インデックス
  y
  実行する cross.set_axis_value "RIGHT" 点インデックス "位置" y

  2
  入れる 点インデックス
  z
  実行する cross.set_axis_value "RIGHT" 点インデックス "位置" z

  # 速度を計算（前フレームとの差分）
  実行する world.calculate_velocity 物体ID

  # 軌跡を記録（BACK軸）
  実行する world.record_trajectory 物体ID

  返す


# 操作コマンド: 物体を隠す
ラベル 物体を隠す

  取り出す 物体ID

  # 重要: 物体は見えなくても存在し続ける（物の永続性）
  物体ID
  実行する world.get_object
  入れる 物体表現

  # BACK軸の「存在」フラグをtrue
  # 「見えない」が「存在しない」ではない
  取り出す 物体表現
  実行する cross.set_axis_value "BACK" 2 "存在" true
  実行する cross.set_axis_value "DOWN" 0 "可視" false

  # 内部表現は維持
  # 位置、速度、アフォーダンスはそのまま

  返す


# 操作コマンド: 物体を探す
ラベル 物体を探す

  取り出す 物体ID

  # 隠れた物体を探す行動
  # 6-12ヶ月児のA-not-B課題

  物体ID
  実行する world.get_object
  入れる 物体表現

  # BACK軸から過去の位置を取得
  取り出す 物体表現
  実行する cross.get_axis_value "BACK" 0 "過去位置"
  入れる 過去位置

  # 最後に見た場所を返す
  取り出す 過去位置
  実行する array.last

  返す


# 操作コマンド: 予測する
ラベル 次の状態を予測

  取り出す dt  # 時間ステップ
  取り出す 物体ID

  物体ID
  実行する world.get_object
  入れる 物体

  # 現在の速度を取得
  取り出す 物体
  実行する cross.get_axis_value "FRONT" 0 "速度"
  入れる vx

  取り出す 物体
  実行する cross.get_axis_value "FRONT" 1 "速度"
  入れる vy

  取り出す 物体
  実行する cross.get_axis_value "FRONT" 2 "速度"
  入れる vz

  # 重力を適用
  取り出す vz
  取り出す dt
  -9.8
  *
  +
  入れる vz_next

  # 予測位置を計算
  取り出す 物体
  実行する cross.get_axis_value "RIGHT" 0 "位置"
  取り出す vx
  取り出す dt
  *
  +
  入れる x_next

  取り出す 物体
  実行する cross.get_axis_value "RIGHT" 1 "位置"
  取り出す vy
  取り出す dt
  *
  +
  入れる y_next

  取り出す 物体
  実行する cross.get_axis_value "RIGHT" 2 "位置"
  取り出す vz_next
  取り出す dt
  *
  +
  入れる z_next

  # 予測をFRONT軸に格納
  取り出す 物体
  実行する cross.set_axis_value "FRONT" 3 "予測位置" [x_next, y_next, z_next]

  # 予測を返す
  取り出す x_next
  取り出す y_next
  取り出す z_next

  返す


# 操作コマンド: 驚きを検出
ラベル 驚きを検出

  取り出す 実際の位置
  取り出す 予測位置

  # 予測誤差を計算
  取り出す 実際の位置
  取り出す 予測位置
  実行する vector.distance
  入れる 誤差

  # 驚き閾値
  0.5
  入れる 閾値

  # 誤差が閾値を超えたら驚き
  取り出す 誤差
  取り出す 閾値
  >
  入れる 驚いた

  # 驚き度を返す
  取り出す 驚いた
  0ならジャンプ 驚かず

  # 驚いた場合
  表示する "驚き！ 予測と違う！"
  取り出す 誤差
  返す

  ラベル 驚かず
  0
  返す


# ═══════════════════════════════════════════════════════════
# 5. 世界モデルの学習
# ═══════════════════════════════════════════════════════════

生成する 世界モデル学習Cross = {
  "UP": [
    {"点": 0, "優先度": 10, "意味": "世界モデルを学習"}
  ],
  "FRONT": [
    {"点": 0, "予測": "次の状態"},
    {"点": 1, "予測モデル": "ニューラルネット or 物理法則"}
  ],
  "BACK": [
    {"点": 0, "実際": "観測"},
    {"点": 1, "予測誤差": "計算"},
    {"点": 2, "誤差で学習": "モデル更新"}
  ],
  "DOWN": [
    {"点": 0, "学習対象": [
      "物理法則のパラメータ",
      "物体の性質",
      "アフォーダンス"
    ]}
  ]
}

# 操作コマンド: 世界モデルを学習
ラベル 世界モデルを学習

  取り出す 実際の状態
  取り出す 予測した状態

  # 予測誤差
  取り出す 実際の状態
  取り出す 予測した状態
  実行する world.prediction_error
  入れる 誤差

  # 誤差でモデルを更新
  取り出す 誤差
  実行する world.update_model

  # 学習率
  0.01
  入れる 学習率

  # モデルパラメータを更新
  実行する world.apply_gradient_descent 学習率 誤差

  返す

# ═══════════════════════════════════════════════════════════
