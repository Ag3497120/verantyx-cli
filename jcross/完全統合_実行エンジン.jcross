    グローバルパターン空間,
    物理シミュレーション反復,
    学習率,
    減衰率
)

表示("✅ 物理シミュレーション完了")
表示("")

// 最終的なCross空間配置を表示
表示("=" * 80)
表示("📐 最終的なCross空間配置:")
表示("")

各パターン IN グローバルパターン空間 {
    品質 = 0.0
    もし 各パターン.使用数 > 0 {
        品質 = 各パターン.成功数 / 各パターン.使用数
    }

    表示("パターン: " + 各パターン.名前)
    表示("  位置: FRONT=" + 文字列(四捨五入(各パターン.位置.前後, 2)) +
                " UP=" + 文字列(四捨五入(各パターン.位置.上下, 2)) +
                " RIGHT=" + 文字列(四捨五入(各パターン.位置.左右, 2)))
    表示("  統計: 使用=" + 文字列(各パターン.使用数) +
                " 成功=" + 文字列(各パターン.成功数) +
                " 品質=" + 文字列(四捨五入(品質, 2)))

    // 位置の解釈
    解釈 = ""
    もし 各パターン.位置.前後 > 0.7 {
        もし 各パターン.位置.上下 > 0.5 {
            解釈 = "高品質・高頻度（FRONT-UP）"
        } そうでなければ {
            解釈 = "高品質・低頻度（FRONT-DOWN）"
        }
    } そうでなければ {
        もし 各パターン.位置.上下 > 0.5 {
            解釈 = "低品質・高頻度（BACK-UP）"
        } そうでなければ {
            解釈 = "低品質・低頻度（BACK-DOWN）"
        }
    }

    表示("  → " + 解釈)
    表示("")
}

