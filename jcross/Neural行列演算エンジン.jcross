表示("  次元数: " + 文字列(大規模次元数))
表示("")

// ダミーパターン生成
大規模パターン群 = []
カウンタ = 0
繰り返し {
    もし カウンタ >= 大規模パターン数 {
        中断
    }

    パターン = {
        名前: "パターン" + 文字列(カウンタ),
        キーワード群: ["キーワード" + 文字列(カウンタ)]
    }
    大規模パターン群 = 大規模パターン群 + [パターン]
    カウンタ = カウンタ + 1
}

表示("パターン生成完了: " + 文字列(長さ(大規模パターン群)) + "個")
表示("")

// 行列化
表示("行列化中...")
大規模行列 = パターン群を行列化(大規模パターン群, 入力文, 大規模次元数)
表示("  ✅ " + 文字列(長さ(大規模行列)) + "×" + 文字列(大規模次元数) + " 行列完成")
表示("")

// 入力ベクトル
大規模入力 = 文字列をベクトル化(入力文, 大規模次元数)

// 並列計算
表示("並列共鳴計算実行中...")
大規模共鳴 = 並列共鳴を計算(大規模行列, 大規模入力)
表示("  ✅ " + 文字列(長さ(大規模共鳴)) + "個の共鳴を一度に計算")
表示("")

