// 実行テスト
// ========================================

表示("🧪 Neural行列演算テスト")
表示("")

// テストデータ
入力文 = "feat: Neural行列演算を.jcrossで実装"
次元数 = 10

パターン群 = [
    {名前: "ギットハブ", キーワード群: ["feat:", "fix:", "git"]},
    {名前: "タスク", キーワード群: ["TODO", "タスク"]},
    {名前: "実装", キーワード群: ["実装", "開発", "コード"]}
]

表示("Step 1: 入力をベクトル化")
入力ベクトル = 文字列をベクトル化(入力文, 次元数)
表示("  ✅ 次元数: " + 文字列(長さ(入力ベクトル)))
表示("  先頭3要素: [" + 文字列(四捨五入(入力ベクトル.0, 3)) + ", " +
                       文字列(四捨五入(入力ベクトル.1, 3)) + ", " +
                       文字列(四捨五入(入力ベクトル.2, 3)) + "]")
表示("")

表示("Step 2: パターン群を行列化")
パターン行列 = パターン群を行列化(パターン群, 入力文, 次元数)
表示("  ✅ 行列サイズ: " + 文字列(長さ(パターン行列)) + "×" + 文字列(次元数))
表示("")

表示("Step 3: 並列共鳴計算（行列演算）")
共鳴スコア群 = 並列共鳴を計算(パターン行列, 入力ベクトル)
表示("  ✅ " + 文字列(長さ(共鳴スコア群)) + "個の共鳴を同時計算")
表示("")

表示("📊 共鳴結果:")
位置 = 0
各スコア IN 共鳴スコア群 {
    パターン = パターン群.位置
    パーセント = 四捨五入(各スコア * 100, 1)
    バー = "█" * 整数(パーセント / 5)

    表示("  " + パターン.名前 + ": [" + バー + "] " + 文字列(パーセント) + "%")
    位置 = 位置 + 1
}
表示("")

