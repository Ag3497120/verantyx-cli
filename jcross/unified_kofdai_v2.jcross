// ========================================
// 共鳴計算関数（キーワードハードコード版）
// ========================================

FUNCTION calculate_github_resonance(text) {
    score = 0.0

    IF CONTAINS(text, "feat:") {
        score = score + 0.166
    }
    IF CONTAINS(text, "fix:") {
        score = score + 0.166
    }
    IF CONTAINS(text, "docs:") {
        score = score + 0.166
    }
    IF CONTAINS(text, "refactor:") {
        score = score + 0.166
    }
    IF CONTAINS(text, "test:") {
        score = score + 0.166
    }
    IF CONTAINS(text, "git") {
        score = score + 0.166
    }

    RETURN score
}

FUNCTION calculate_todo_resonance(text) {
    score = 0.0

    IF CONTAINS(text, "TODO") {
        score = score + 0.2
    }
    IF CONTAINS(text, "タスク") {
        score = score + 0.2
    }
    IF CONTAINS(text, "明日") {
        score = score + 0.2
    }
    IF CONTAINS(text, "予定") {
        score = score + 0.2
    }
    IF CONTAINS(text, "締め切り") {
        score = score + 0.2
    }

    RETURN score
}

FUNCTION calculate_question_resonance(text) {
    score = 0.0

    IF CONTAINS(text, "とは") {
        score = score + 0.166
    }
    IF CONTAINS(text, "って何") {
        score = score + 0.166
    }
    IF CONTAINS(text, "どうやって") {
        score = score + 0.166
    }
    IF CONTAINS(text, "なぜ") {
        score = score + 0.166
    }
    IF CONTAINS(text, "how") {
        score = score + 0.166
    }
    IF CONTAINS(text, "what") {
        score = score + 0.166
    }

    RETURN score
}

FUNCTION calculate_thought_resonance(text) {
    score = 0.0

    IF CONTAINS(text, "哲学") {
        score = score + 0.2
    }
    IF CONTAINS(text, "思考") {
        score = score + 0.2
    }
    IF CONTAINS(text, "概念") {
        score = score + 0.2
    }
    IF CONTAINS(text, "アイデア") {
        score = score + 0.2
    }
    IF CONTAINS(text, "理論") {
        score = score + 0.2
    }

    RETURN score
}

// ========================================
// Cross空間位置更新
// ========================================

FUNCTION update_pattern_position(pattern) {
    // 品質 = 成功率
    IF pattern.usage_count > 0 {
        pattern.quality = pattern.success_count / pattern.usage_count
    } ELSE {
        pattern.quality = 0.5
    }

    // FRONT/BACK: 品質（成功率）
    pattern.front_back = pattern.quality

    // UP/DOWN: 使用頻度
    pattern.up_down = pattern.usage_count / 100.0
    IF pattern.up_down > 1.0 {
        pattern.up_down = 1.0
    }

    // LEFT/RIGHT: 新しさ
    age = NOW() - pattern.created_at
    age_days = age / 86400.0
    pattern.left_right = 1.0 - (age_days / 365.0)
    IF pattern.left_right < 0.0 {
        pattern.left_right = 0.0
    }

    RETURN pattern
}

// ========================================
// 全同調エンジン
// ========================================

FUNCTION process_input_wave(text) {
    PRINT("=" * 60)
    PRINT("🌊 New Input Wave")
    PRINT("   Input: " + text)
    PRINT("=" * 60)
    PRINT("")

    // 全パターンで共鳴計算（並列）
    PRINT("🔄 Calculating resonances...")
    PRINT("")

    score_github = calculate_github_resonance(text)
    score_todo = calculate_todo_resonance(text)
    score_question = calculate_question_resonance(text)
    score_thought = calculate_thought_resonance(text)

    PRINT("   📡 " + github_pattern.name + ": " + STR(ROUND(score_github * 100, 1)) + "%")
    PRINT("   📡 " + todo_pattern.name + ": " + STR(ROUND(score_todo * 100, 1)) + "%")
    PRINT("   📡 " + question_pattern.name + ": " + STR(ROUND(score_question * 100, 1)) + "%")
    PRINT("   📡 " + thought_pattern.name + ": " + STR(ROUND(score_thought * 100, 1)) + "%")

    PRINT("")

    // Logic Resolution: 最大共鳴を選択
    best_name = "none"
    best_score = 0.0
    best_action = "learn_new_pattern"
    best_threshold = 0.5
    best_pattern = {name: "none", usage_count: 0}

    IF score_github > best_score {
        best_name = github_pattern.name
        best_score = score_github
        best_action = github_pattern.action
        best_threshold = github_pattern.threshold
        best_pattern = github_pattern
    }

    IF score_todo > best_score {
        best_name = todo_pattern.name
        best_score = score_todo
        best_action = todo_pattern.action
        best_threshold = todo_pattern.threshold
        best_pattern = todo_pattern
    }

    IF score_question > best_score {
        best_name = question_pattern.name
        best_score = score_question
        best_action = question_pattern.action
        best_threshold = question_pattern.threshold
        best_pattern = question_pattern
    }

    IF score_thought > best_score {
        best_name = thought_pattern.name
        best_score = score_thought
        best_action = thought_pattern.action
        best_threshold = thought_pattern.threshold
        best_pattern = thought_pattern
    }

    PRINT("🎯 Logic Resolution")
    PRINT("   Best match: " + best_name)
    PRINT("   Score: " + STR(ROUND(best_score * 100, 1)) + "%")
    PRINT("   Threshold: " + STR(ROUND(best_threshold * 100, 1)) + "%")
    PRINT("")

    confidence = "low"
    executed = false

    IF best_score >= best_threshold {
        PRINT("   ✅ High Confidence → Execute: " + best_action)
        confidence = "high"
        executed = true
    } ELSE {
        IF best_score >= 0.5 {
            PRINT("   ⚡ Medium Confidence → Suggest: " + best_action)
            confidence = "medium"
        } ELSE {
            PRINT("   ❓ Low Confidence → Learn Mode")
            confidence = "low"
        }
    }

    PRINT("")

    // パターン使用統計を更新し、Cross空間で再配置
    IF best_pattern.usage_count >= 0 {
        old_front = best_pattern.front_back
        old_up = best_pattern.up_down

        best_pattern.usage_count = best_pattern.usage_count + 1

        IF executed {
            best_pattern.success_count = best_pattern.success_count + 1
        }

        best_pattern = update_pattern_position(best_pattern)

        PRINT("📍 Pattern repositioned in Cross space")
        PRINT("   FRONT: " + STR(ROUND(old_front, 2)) + " → " + STR(ROUND(best_pattern.front_back, 2)))
        PRINT("   UP: " + STR(ROUND(old_up, 2)) + " → " + STR(ROUND(best_pattern.up_down, 2)))

        IF executed {
            PRINT("   ✅ Successful pattern moved toward FRONT-UP")
        }

        PRINT("")
    }

    result = {
        action: best_action,
        confidence: confidence,
        score: best_score
    }

    RETURN result
}

